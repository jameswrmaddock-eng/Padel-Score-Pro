{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/robots.txt",
      "dest": "/robots.txt",
      "headers": { "Content-Type": "text/plain" }
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml",
      "headers": { "Content-Type": "application/xml" }
    },
    {
      "src": "/llms.txt",
      "dest": "/llms.txt",
      "headers": { "Content-Type": "text/plain" }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
